{
  "name": "wallet-aggregator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Wallet data aggregator gateway",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "migrate": "tsx scripts/migrate.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@wallet-platform/canonical": "workspace:*",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "helmet": "^8.2.0",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^11.1.0",
    "pg": "^8.21.0",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.21",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.3",
    "typescript": "^6.0.3"
  }
}
