PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wallet_aggregator
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-jwt-secret-at-least-32-characters
INTERNAL_API_KEY=change-me-internal-api-key-32chars-min

# JSON: chainId -> provider config
CHAINS_JSON={"1":{"provider":"indexer","endpoint":"http://localhost:3001","internalApiKey":"change-me-internal-api-key-32chars-min"}}

CORS_ORIGINS=
COINGECKO_API_KEY=
PRICE_CACHE_TTL_SECONDS=300

# Webhook 投递
WEBHOOK_DELIVERY_TIMEOUT_MS=10000
WEBHOOK_MAX_RETRIES=5
WEBHOOK_RETRY_INTERVAL_MS=30000
# Alchemy Notify 签名校验（生产环境必填）
ALCHEMY_WEBHOOK_SIGNING_KEY=

LOG_LEVEL=info
LOG_FILE=./logs/aggregator.log

# 示例：Ethereum 走 Indexer，Polygon 走 Alchemy
# CHAINS_JSON={"1":{"provider":"indexer","endpoint":"http://localhost:3001","internalApiKey":"..."},"137":{"provider":"alchemy","apiKey":"...","network":"polygon-mainnet"}}
