NODE_ENV=development
CHAIN_ID=1
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wallet_indexer
REDIS_URL=redis://localhost:6379
RPC_HTTP_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
RPC_WS_URL=wss://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
PORT=3001

INTERNAL_API_KEY=change-me-internal-api-key-32chars-min
AGGREGATOR_EVENT_URL=http://localhost:3000/internal/v1/events/chain-activity

CONFIRMATION_DEPTH=12
BACKFILL_MAX_BLOCK_RANGE=2000
BACKFILL_OVERLAP_BLOCKS=2
INDEXER_START_LOOKBACK_BLOCKS=100000
REORG_SCAN_DEPTH=128
REORG_SCAN_INTERVAL_MS=60000
GAP_BACKFILL_INTERVAL_MS=60000
MAX_INLINE_GAP_BLOCKS=500
ANCHOR_PREFETCH_CONCURRENCY=32

NFT_SYNC_INTERVAL_MS=30000
ENRICH_INTERVAL_MS=5000
ENRICH_BATCH_SIZE=20
METADATA_INTERVAL_MS=10000
NATIVE_WATCH_INTERVAL_MS=60000
NATIVE_WATCH_MAX_BLOCKS_PER_TICK=100

DB_API_POOL_MAX=8
DB_WORKER_POOL_MAX=12
DB_MAX_CONCURRENT_WRITE_TX=3
DB_CONNECTION_TIMEOUT_MS=5000
DB_IDLE_TIMEOUT_MS=30000
DB_API_STATEMENT_TIMEOUT_MS=15000
DB_WORKER_STATEMENT_TIMEOUT_MS=120000

LOG_LEVEL=info
